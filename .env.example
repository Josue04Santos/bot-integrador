# ════════════════════════════════════════════════════════════
# 🤖 BOT INTEGRADOR EQTL — Variáveis de Ambiente
# ════════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env real no git!

# ─── TELEGRAM BOT (aiogram) ────────────────────────────────
TELEGRAM_BOT_TOKEN=
WEBHOOK_ENABLED=false
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# ─── USERBOT (Telethon) ────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
BOT_TERCEIRO_USERNAME=ReincidenciasBot
BOT_TERCEIRO_TIMEOUT=30
TELEGRAM_SOURCE_CHAT_ID=0

# ─── BANCO DE DADOS (PostgreSQL — produção) ────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bot_integrador
POSTGRES_USER=bot_user
POSTGRES_PASSWORD=

# ─── APLICAÇÃO ─────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# ─── API REST ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
